generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  WORKER
}

enum TaskCategory {
  POST
  COMMENT
  REPLY
}

enum TaskStatus {
  AVAILABLE
  CLAIMED
  SUBMITTED
  APPROVED
  REJECTED
  NEEDS_REVISION
  EXPIRED
}

enum TransactionType {
  TASK_APPROVAL
  REFERRAL_REWARD
  REFERRAL_BONUS
  ADJUSTMENT
  PAYOUT
}

enum ReferralStatus {
  PENDING
  SUCCESSFUL
  REJECTED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  username       String    @unique
  role           Role      @default(WORKER)
  redditUsername String?
  suspended      Boolean   @default(false)
  suspendedAt    DateTime?
  claimBanned    Boolean   @default(false)
  claimBannedAt  DateTime?
  createdAt      DateTime  @default(now())
  lastLoginAt    DateTime?
  lastActiveAt   DateTime?
  lastLoginIp    String?
  lastClaimAt    DateTime?
  referralCode   String    @unique
  discordId      String?   @unique
  discordUsername String?
  discordAvatar  String?
  discordLinkedAt DateTime?
  discordUnlinkedAt DateTime?

  claimedTasks Task[]               @relation("ClaimedBy")
  createdTasks Task[]               @relation("CreatedTasks")
  submissions  Submission[]
  transactions BalanceTransaction[]
  reviewedSubs Submission[]         @relation("ReviewedBy")
  referralsMade Referral[]          @relation("Referrer")
  referralReceived Referral?        @relation("Referred")

  @@index([role])
  @@index([lastActiveAt])
  @@index([role, lastActiveAt])
}

model Referral {
  id          String         @id @default(cuid())
  referrerId  String
  referrer    User           @relation("Referrer", fields: [referrerId], references: [id])
  referredId  String         @unique
  referred    User           @relation("Referred", fields: [referredId], references: [id])
  status      ReferralStatus @default(PENDING)
  rewardedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([referrerId, status])
}

model Task {
  id             String       @id @default(cuid())
  category       TaskCategory
  platform       String       @default("reddit")
  targetUrl      String
  instructions   String       @db.Text
  rewardSnapshot Decimal      @db.Decimal(10, 2)
  status         TaskStatus   @default(AVAILABLE)
  scheduledFor   DateTime?
  isPaused       Boolean      @default(false)

  claimedById    String?
  claimedBy      User?        @relation("ClaimedBy", fields: [claimedById], references: [id])
  claimedAt      DateTime?
  claimExpiresAt DateTime?

  createdById    String
  createdBy      User         @relation("CreatedTasks", fields: [createdById], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  submission     Submission?

  @@index([status])
  @@index([category])
  @@index([claimedById])
  @@index([status, category, createdAt])
  @@index([status, isPaused, scheduledFor])
  @@index([claimedById, status])
  @@index([createdById])
}

model Submission {
  id       String @id @default(cuid())
  taskId   String @unique
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  workerId String
  worker   User   @relation(fields: [workerId], references: [id])

  mainLink    String
  randomLink1 String
  randomLink2 String
  randomLink3 String

  status TaskStatus @default(SUBMITTED)

  reviewedById String?
  reviewedBy   User?     @relation("ReviewedBy", fields: [reviewedById], references: [id])

  reviewedAt DateTime?
  adminNote  String? @db.Text

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workerId])
  @@index([status])
  @@index([mainLink])
  @@index([workerId, submittedAt])
  @@index([status, submittedAt])
  @@index([reviewedById])
}

model BalanceTransaction {
  id        String          @id @default(cuid())
  workerId  String
  worker    User            @relation(fields: [workerId], references: [id])

  taskId String?

  amount Decimal @db.Decimal(10, 2)

  type TransactionType

  note String?

  createdAt DateTime @default(now())

  @@index([workerId])
  @@index([createdAt])
  @@index([workerId, type])
}

model GlobalSettings {
  id               String   @id @default("singleton")

  postReward       Decimal  @default(2.00) @db.Decimal(10, 2)
  commentReward    Decimal  @default(1.00) @db.Decimal(10, 2)
  replyReward      Decimal  @default(0.50) @db.Decimal(10, 2)

  claimCooldownMin Int @default(30)
  claimTimeoutMin  Int @default(60)
  maxActiveTasks   Int @default(3)
  referralReward   Decimal @default(0) @db.Decimal(10, 2)
  referredWorkerBonus Decimal @default(0) @db.Decimal(10, 2)
  discordSupportUrl  String?

  updatedAt DateTime @updatedAt
}
