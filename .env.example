# Supabase Postgres connection strings.
# DATABASE_URL uses the pooled connection (port 6543) for the app at runtime.
# DIRECT_URL uses the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Discord OAuth (create these in the Discord Developer Portal)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN=""
DISCORD_PUBLIC_KEY=""
DISCORD_GUILD_ID="" # Optional: makes command updates appear immediately in one test server.
DISCORD_TASKS_CHANNEL_ID="" # The channel where minimal task-count alerts are posted.

# Used only by prisma/seed.ts to create the first admin account
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
