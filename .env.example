# Supabase Postgres connection strings.
# DATABASE_URL uses the pooled connection (port 6543) for the app at runtime.
# DIRECT_URL uses the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Used only by prisma/seed.ts to create the first admin account
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
